{
  "name": "quickcel-clone",
  "version": "1.0.0",
  "description": "QuickCel clone - Excel Add-in with customizable keyboard shortcuts for financial modeling",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "start": "webpack serve --mode development",
    "lint": "tslint -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "certs": "office-addin-dev-certs install",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.110",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.421",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-loader": "^5.1.0",
    "mini-css-extract-plugin": "^2.9.2",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-manifest": "^2.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
